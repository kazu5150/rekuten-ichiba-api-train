# Rakuten API Configuration
# Get your application ID from: https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=your_application_id_here

# Google Sheets API Configuration
# Follow these steps to get credentials:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google Sheets API
# 4. Create credentials (Service Account)
# 5. Download the JSON file and place it in the project directory
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_ID=your_spreadsheet_id_here